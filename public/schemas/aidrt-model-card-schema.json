{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AID-RT Model Card Schema",
  "description": "Matches the exact upstream schema from https://github.com/MIRO-UCLouvain/RT-AI-Model-Card/blob/main/app/core/schemas/model_card_schema.json. Paper: https://doi.org/10.1016/j.phro.2026.100940",
  "version": "2.0.0",
  "sections": {
    "card_metadata": {
      "description": "Metadata about the model card document itself",
      "fields": {
        "card_creation_date": { "type": "date", "required": true, "description": "Date of creation of the card" },
        "version_number": { "type": "string", "required": true, "description": "Version number of the card" },
        "version_changes": { "type": "string", "required": true, "description": "Main changes since previous version, or 'NA' for first version" },
        "doi": { "type": "string", "required": false, "description": "DOI of the model card if published" }
      }
    },
    "model_basic_information": {
      "description": "Core model identification, scope, regulatory status, and developer info",
      "fields": {
        "name": { "type": "string", "required": true, "description": "Name of the model", "dlinrtMapping": "name" },
        "creation_date": { "type": "date", "required": true, "description": "Date when the model was created/trained" },
        "version_number": { "type": "string", "required": true, "description": "Model version number (MM.mm.bbbb)", "dlinrtMapping": "version" },
        "version_changes": { "type": "string", "required": true, "description": "Changes from previous model version" },
        "doi": { "type": "string", "required": false, "description": "DOI of the model" },
        "model_scope_summary": { "type": "string", "required": true, "description": "One sentence summary of what the model does", "dlinrtMapping": "category + description" },
        "model_scope_anatomical_site": { "type": "select", "required": true, "description": "General body site (Brain, HN, Thorax, Abdomen, Pelvis, Other)", "dlinrtMapping": "anatomy" },
        "clearance_type": { "type": "string", "required": true, "description": "Regulatory clearance status", "dlinrtMapping": "regulatory.ce + regulatory.fda" },
        "clearance_approved_by_name": { "type": "string", "required": false, "description": "Name(s) of persons who approved the model" },
        "clearance_approved_by_institution": { "type": "string", "required": true, "description": "Institution(s) involved in approval", "dlinrtMapping": "company" },
        "clearance_approved_by_contact_email": { "type": "string", "required": false, "description": "Contact email for approval team", "dlinrtMapping": "contactEmail" },
        "clearance_additional_information": { "type": "string", "required": false, "description": "Additional approval/clearance info" },
        "intended_users": { "type": "string", "required": false, "description": "Intended users of the model" },
        "observed_limitations": { "type": "string", "required": true, "description": "Known biases or limitations", "dlinrtMapping": "limitations" },
        "potential_limitations": { "type": "string", "required": false, "description": "Potential biases or limitations" },
        "type_of_learning_architecture": { "type": "string", "required": true, "description": "Architecture type (CNN, UNet, Transformers, etc.)" },
        "developed_by_name": { "type": "string", "required": false, "description": "Developer name(s)" },
        "developed_by_institution": { "type": "string", "required": true, "description": "Developer institution(s)", "dlinrtMapping": "company" },
        "developed_by_email": { "type": "string", "required": false, "description": "Developer contact email", "dlinrtMapping": "contactEmail" },
        "conflict_of_interest": { "type": "string", "required": true, "description": "Conflict of interest disclosure" },
        "software_license": { "type": "string", "required": true, "description": "Software licence (Apache 2.0, GPL, MIT, etc.)" },
        "code_source": { "type": "string", "required": false, "description": "Link to source code repository" },
        "model_source": { "type": "string", "required": false, "description": "Link to trained model weights" },
        "citation_details": { "type": "string", "required": false, "description": "Associated scientific papers" },
        "url_info": { "type": "string", "required": false, "description": "Link to more information", "dlinrtMapping": "productUrl" }
      }
    },
    "technical_specifications": {
      "description": "Model pipeline, inputs, outputs, and processing details",
      "fields": {
        "model_pipeline_summary": { "type": "string", "required": true, "description": "Summary of full model pipeline in inference mode", "dlinrtMapping": "technology.integration" },
        "model_pipeline_figure": { "type": "image", "required": false, "description": "Figure illustrating the pipeline" },
        "model_inputs": { "type": "select", "required": true, "description": "Model input data types (CT, MR, etc.)", "dlinrtMapping": "technicalSpecifications.input" },
        "additional_information_model_inputs": { "type": "string", "required": false, "description": "Additional input info", "dlinrtMapping": "technicalSpecifications.inputFormat" },
        "model_outputs": { "type": "select", "required": true, "description": "Model output data types", "dlinrtMapping": "technicalSpecifications.output" },
        "additional_information_model_outputs": { "type": "string", "required": false, "description": "Additional output info", "dlinrtMapping": "technicalSpecifications.outputFormat" },
        "pre_processing": { "type": "string", "required": true, "description": "Pre-processing operations" },
        "post_processing": { "type": "string", "required": true, "description": "Post-processing operations" }
      }
    },
    "learning_architecture": {
      "description": "Model training architecture details",
      "fields": {
        "total_number_trainable_parameters": { "type": "integer", "required": true, "description": "Total trainable parameters" },
        "number_of_inputs": { "type": "integer", "required": false, "description": "Number of inputs (channels, tokens, etc.)" },
        "input_content": { "type": "select", "required": false, "description": "Expected content of each input" },
        "additional_information_input_content": { "type": "string", "required": false, "description": "Further input specification" },
        "input_format": { "type": "string", "required": false, "description": "Matrix format of each input" },
        "input_size": { "type": "string", "required": false, "description": "Size of each input" },
        "number_of_outputs": { "type": "integer", "required": false, "description": "Number of outputs" },
        "output_content": { "type": "select", "required": false, "description": "Modalities of each output" },
        "additional_information_output_content": { "type": "string", "required": false, "description": "Further output specification" },
        "output_format": { "type": "string", "required": false, "description": "Matrix format of each output" },
        "output_size": { "type": "string", "required": false, "description": "Size of each output" },
        "loss_function": { "type": "string", "required": true, "description": "Loss function used for training" },
        "batch_size": { "type": "integer", "required": false, "description": "Training batch size" },
        "regularisation": { "type": "string", "required": false, "description": "Regularisation technique" },
        "architecture_figure": { "type": "image", "required": true, "description": "Learning architecture figure" },
        "uncertainty_quantification_techniques": { "type": "string", "required": true, "description": "Uncertainty quantification methods or 'NA'" },
        "explainability_techniques": { "type": "string", "required": true, "description": "Explainability techniques or 'NA'" },
        "additional_information_ts": { "type": "string", "required": false, "description": "Additional architecture info" },
        "citation_details_ts": { "type": "string", "required": false, "description": "Associated papers for architecture" }
      }
    },
    "hw_and_sw": {
      "description": "Hardware and software requirements",
      "fields": {
        "libraries_and_dependencies": { "type": "string", "required": false, "description": "Software libraries and dependencies" },
        "hardware_recommended": { "type": "string", "required": false, "description": "Recommended hardware for inference" },
        "inference_time_for_recommended_hw": { "type": "float", "required": false, "description": "Inference time in seconds" },
        "installation_getting_started": { "type": "string", "required": false, "description": "URL to installation procedure" },
        "environmental_impact": { "type": "string", "required": false, "description": "Carbon emissions and environmental impact" }
      }
    },
    "training_data": {
      "description": "Training dataset characteristics, methodology, and training hyperparameters",
      "fields": {
        "model_name": { "type": "string", "required": true, "description": "Name of base model if fine-tuned, or 'NA'", "dlinrtMapping": "name" },
        "url_doi_to_model_card": { "type": "string", "required": true, "description": "URL/DOI to base model card, or 'NA'" },
        "tuning_technique": { "type": "string", "required": true, "description": "Tuning technique, or 'NA'" },
        "total_size": { "type": "list[int]", "required": true, "description": "Number of total training samples", "dlinrtMapping": "trainingData.datasetSize" },
        "number_of_patients": { "type": "integer", "required": true, "description": "Number of unique patients" },
        "source": { "type": "string", "required": true, "description": "Data source(s)", "dlinrtMapping": "trainingData.datasetSources" },
        "acquisition_period": { "type": "string", "required": true, "description": "Data acquisition period" },
        "inclusion_exclusion_criteria": { "type": "string", "required": true, "description": "Patient inclusion/exclusion criteria" },
        "type_of_data_augmentation": { "type": "string", "required": false, "description": "Data augmentation operations" },
        "strategy_for_data_augmentation": { "type": "string", "required": false, "description": "Data augmentation strategy" },
        "url_info": { "type": "string", "required": false, "description": "URL to dataset description" },
        "image_resolution": { "type": "list[float]", "required": true, "description": "Pixel/voxel resolution in mm" },
        "patient_positioning": { "type": "string", "required": true, "description": "Patient positioning" },
        "scanner_model": { "type": "string", "required": true, "description": "Scanner manufacturer and model", "dlinrtMapping": "trainingData.scannerModels" },
        "scan_acquisition_parameters": { "type": "string", "required": true, "description": "Acquisition parameters (kV, TR, TE)" },
        "scan_reconstruction_parameters": { "type": "string", "required": true, "description": "Reconstruction algorithm and parameters" },
        "fov": { "type": "list[float]", "required": true, "description": "Field of View in mm" },
        "treatment_modality_train": { "type": "select", "required": true, "description": "RT treatment technique (dose prediction only)" },
        "beam_configuration_energy": { "type": "string", "required": true, "description": "Beam configuration (dose prediction only)" },
        "dose_engine": { "type": "select", "required": true, "description": "Dose engine used (dose prediction only)" },
        "target_volumes_and_prescription": { "type": "string", "required": true, "description": "Target volumes and Rx (dose prediction only)" },
        "number_of_fractions": { "type": "list[float]", "required": true, "description": "Fractions per Rx (dose prediction only)" },
        "reference_standard": { "type": "string", "required": true, "description": "Reference standard methods" },
        "reference_standard_qa": { "type": "string", "required": true, "description": "Reference standard QA methods" },
        "reference_standard_qa_additional_information": { "type": "string", "required": false, "description": "Additional QA info" },
        "icd10_11": { "type": "string[]", "required": false, "description": "ICD10/11 codes" },
        "tnm_staging": { "type": "string", "required": false, "description": "TNM staging details" },
        "age": { "type": "string", "required": true, "description": "Patient age median and range", "dlinrtMapping": "trainingData.demographics" },
        "sex": { "type": "string", "required": true, "description": "Sex distribution (M/F/O)" },
        "target_volume_cm3": { "type": "string[]", "required": false, "description": "Target volume statistics" },
        "bmi": { "type": "string", "required": false, "description": "BMI median and range" },
        "additional_patient_info": { "type": "string", "required": false, "description": "Additional patient demographics" },
        "validation_strategy": { "type": "string", "required": true, "description": "Validation strategy" },
        "validation_data_partition": { "type": "string", "required": true, "description": "Validation data partition %" },
        "weights_initialization": { "type": "string", "required": false, "description": "Weight initialization technique" },
        "epochs": { "type": "list[int]", "required": false, "description": "Number of training epochs" },
        "optimiser": { "type": "string", "required": false, "description": "Optimiser algorithm" },
        "learning_rate": { "type": "string", "required": false, "description": "Learning rate and/or scheduler" },
        "train_and_validation_loss_curves": { "type": "image", "required": true, "description": "Training and validation loss curves" },
        "model_choice_criteria": { "type": "string", "required": true, "description": "Criteria for choosing final model" },
        "inference_method": { "type": "string", "required": true, "description": "Method to obtain final prediction" }
      }
    },
    "evaluation_data_methodology_results_commisioning": {
      "description": "Evaluation/testing dataset, methodology, metrics, and commissioning",
      "fields": {
        "evaluation_date": { "type": "date", "required": true, "description": "Date of evaluation" },
        "evaluated_by_name": { "type": "string", "required": true, "description": "Name(s) of evaluator(s)" },
        "evaluated_by_institution": { "type": "string", "required": true, "description": "Evaluating institution(s)", "dlinrtMapping": "company" },
        "evaluated_by_contact_email": { "type": "string", "required": true, "description": "Evaluator contact email", "dlinrtMapping": "contactEmail" },
        "evaluation_frame": { "type": "string", "required": true, "description": "Evaluation conditions (retrospective, prospective)", "dlinrtMapping": "evaluationData.studyDesign" },
        "sanity_check": { "type": "string", "required": true, "description": "Sanity check description (image-to-image only)" },
        "total_size": { "type": "list[int]", "required": true, "description": "Number of evaluation samples", "dlinrtMapping": "evaluationData.datasetSize" },
        "number_of_patients": { "type": "integer", "required": true, "description": "Number of evaluation patients" },
        "source": { "type": "string", "required": true, "description": "Evaluation data source(s)" },
        "acquisition_period": { "type": "string", "required": true, "description": "Data acquisition period" },
        "inclusion_exclusion_criteria": { "type": "string", "required": true, "description": "Inclusion/exclusion criteria" },
        "url_info": { "type": "string", "required": false, "description": "URL to dataset info" },
        "image_resolution": { "type": "list[float]", "required": true, "description": "Pixel/voxel resolution in mm" },
        "patient_positioning": { "type": "string", "required": true, "description": "Patient positioning" },
        "scanner_model": { "type": "string", "required": true, "description": "Scanner manufacturer and model" },
        "scan_acquisition_parameters": { "type": "string", "required": true, "description": "Acquisition parameters" },
        "scan_reconstruction_parameters": { "type": "string", "required": true, "description": "Reconstruction parameters" },
        "fov": { "type": "list[float]", "required": true, "description": "Field of View in mm" },
        "treatment_modality_eval": { "type": "select", "required": true, "description": "RT treatment technique (dose prediction only)" },
        "beam_configuration_energy": { "type": "string", "required": true, "description": "Beam configuration (dose prediction only)" },
        "dose_engine": { "type": "select", "required": true, "description": "Dose engine (dose prediction only)" },
        "target_volumes_and_prescription": { "type": "string", "required": true, "description": "Target volumes and Rx (dose prediction only)" },
        "number_of_fractions": { "type": "list[float]", "required": true, "description": "Fractions per Rx (dose prediction only)" },
        "reference_standard": { "type": "string", "required": true, "description": "Reference standard methods" },
        "reference_standard_qa": { "type": "string", "required": true, "description": "Reference standard QA" },
        "reference_standard_qa_additional_information": { "type": "string", "required": false, "description": "Additional QA info" },
        "icd10_11_ev": { "type": "string[]", "required": false, "description": "ICD10/11 codes" },
        "tnm_staging_ev": { "type": "string", "required": false, "description": "TNM staging details" },
        "age_ev": { "type": "string", "required": true, "description": "Patient age median and range" },
        "sex_ev": { "type": "string", "required": true, "description": "Sex distribution" },
        "target_volume_cm3_ev": { "type": "string[]", "required": false, "description": "Target volume statistics" },
        "bmi_ev": { "type": "string", "required": false, "description": "BMI distribution" },
        "additional_patient_info_ev": { "type": "string", "required": false, "description": "Additional patient info" },
        "type_ism": { "type": "select", "required": true, "description": "Image similarity metric type (image-to-image only)" },
        "on_volume_ism": { "type": "select", "required": true, "description": "Volume for metric computation (image-to-image only)" },
        "registration_dm": { "type": "select", "required": true, "description": "Registration type between real and synthetic images (image-to-image only)" }
      }
    }
  }
}
